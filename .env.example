# --- Server master key for encrypting Pinecone API keys at rest ---
# Generate with: openssl rand -base64 32
MIGRATOR_MASTER_KEY=replace-me-with-32-byte-base64

# --- Postgres ---
POSTGRES_USER=migrator
POSTGRES_PASSWORD=migrator
POSTGRES_DB=migrator
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://migrator:migrator@localhost:5432/migrator

# --- Redis (BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Redpanda / Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=pinecone-migrator

# --- API ---
API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000

# --- Web ---
# Local pnpm dev: point at your Fastify API.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Docker Compose defaults use NEXT_PUBLIC_API_URL=/migrator-api and INTERNAL_API_URL=http://api:4000
# (same-origin proxy). Override only if you know you need a different setup.

# --- Logging ---
LOG_LEVEL=info
