{
  "name": "pinecone-vector-migrator",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted web app for copying Pinecone vectors between indexes/namespaces with cost estimation and zero-downtime sync.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel --stream dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "clean": "pnpm -r exec rimraf dist .next .turbo node_modules/.cache"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  }
}
